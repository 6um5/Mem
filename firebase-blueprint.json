{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A player in a game room",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "points": { "type": "number" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "points", "isOnline"]
    },
    "Room": {
      "title": "Room",
      "description": "A game room for Meme Battle",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "status": { "type": "string", "enum": ["lobby", "writing", "revealing", "voting", "results", "winner"] },
        "settings": {
          "type": "object",
          "properties": {
            "maxPoints": { "type": "number" },
            "roundTime": { "type": "number" }
          }
        },
        "currentMeme": {
          "type": "object",
          "properties": {
            "url": { "type": "string" },
            "title": { "type": "string" }
          }
        },
        "players": { "type": "object" },
        "captions": { "type": "object" },
        "votes": { "type": "object" },
        "revealIndex": { "type": "number" },
        "roundEndTime": { "type": "string", "format": "date-time" },
        "winner": { "type": "string" }
      },
      "required": ["hostId", "status", "settings", "players"]
    }
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "The main game state for a room"
    }
  }
}
